{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vite/**", "out/**"]
    },
    "@pipelab/cli#build": {
      "dependsOn": ["^build", "@pipelab/ui#build"]
    },
    "pkg": {
      "dependsOn": ["build"],
      "outputs": ["bin/**"]
    },
    "package": {
      "dependsOn": ["^build", "build", "^pkg"],
      "outputs": ["out/**"]
    },
    "make": {
      "dependsOn": ["build", "^pkg"],
      "outputs": ["out/**"]
    },
    "publish": {
      "dependsOn": ["build", "^pkg"],
      "outputs": ["out/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  },
  "globalEnv": [
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_PROJECT_ID",
    "POSTHOG_API_KEY"
  ],
  "globalPassThroughEnv": [
    "DEBUG",
    "APPLE_TEAM_ID",
    "APPLE_ID",
    "APPLE_ID_PASSWORD",
    "APPLE_CODESIGN_IDENTITY"
  ]
}
