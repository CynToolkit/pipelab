{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vite/**", "out/**"]
    },
    "@pipelab/cli#build": {
      "dependsOn": ["^build", "@pipelab/ui#build"]
    },
    "pkg": {
      "dependsOn": ["build"],
      "outputs": ["bin/**"]
    },
    "package": {
      "dependsOn": ["^build", "build", "^pkg"],
      "outputs": ["out/**"]
    },
    "make": {
      "dependsOn": ["build", "^pkg"],
      "outputs": ["out/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
