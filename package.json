{
  "name": "pipelab-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e:raw": "pnpm --filter @pipelab/cli test:e2e:raw",
    "test:e2e": "pnpm --filter @pipelab/cli test:e2e",
    "typecheck": "turbo typecheck",
    "format": "oxfmt .",
    "changeset": "changeset",
    "supa:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/shared/src/database.types.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@pipelab/constants": "workspace:*",
    "@pipelab/core-node": "workspace:*",
    "@pipelab/plugin-core": "workspace:*",
    "@pipelab/plugin-filesystem": "workspace:*",
    "@pipelab/shared": "workspace:*",
    "@pipelab/tsconfig": "workspace:*",
    "@types/node": "24.12.2",
    "@types/tar": "^6.1.13",
    "cross-env": "7.0.3",
    "execa": "9.5.1",
    "nanoid": "5.0.8",
    "oxfmt": "0.40.0",
    "oxlint": "1.55.0",
    "turbo": "^2.8.15",
    "typescript": "5.9.3",
    "vitest": "3.1.4"
  },
  "resolutions": {
    "@codemirror/state": "6.4.1",
    "vue-demi": "0.14.10"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "@codemirror/state": "6.4.1"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "core-js",
      "electron",
      "electron-winstaller",
      "esbuild",
      "fs-xattr",
      "macos-alias",
      "msw",
      "sharp",
      "vue-demi"
    ]
  },
  "license": "FSL-1.1-MIT"
}
