{
  "name": "@pipelab/plugin-core",
  "version": "1.0.1-beta.19",
  "description": "Core library for building Pipelab plugins",
  "license": "FSL-1.1-MIT",
  "author": "CynToolkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/CynToolkit/pipelab.git",
    "directory": "plugins/plugin-core"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "browser": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "default": "./dist/index.mjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "scripts": {
    "build": "tsdown",
    "format": "oxfmt .",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@pipelab/core-node": "workspace:*",
    "@types/node": "^24.12.2",
    "archiver": "7.0.1",
    "electron": "32.1.2",
    "execa": "9.4.1",
    "pacote": "21.5.0",
    "tar": "6.2.1",
    "type-fest": "4.26.1",
    "yauzl": "2.10.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@pipelab/constants": "workspace:*",
    "@pipelab/shared": "workspace:*",
    "@pipelab/tsconfig": "workspace:*",
    "@types/archiver": "7.0.0",
    "@types/pacote": "11.1.8",
    "@types/tar": "7.0.87",
    "@types/yauzl": "2.10.3",
    "tsdown": "0.21.2",
    "typescript": "5.9.3"
  }
}
