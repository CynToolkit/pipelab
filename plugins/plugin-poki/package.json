    "build": "tsdown"
  },
  "dependencies": {
    "@pipelab/plugin-core": "workspace:*"
  },
  "devDependencies": {
    "@pipelab/test-utils": "workspace:*",
    "@pipelab/tsconfig": "workspace:*",
    "@types/node": "24",
    "electron": "32.1.2",
    "msw": "2.7.5",
    "tsdown": "0.21.2",
    "typescript": "5.9.3",
    "vitest": "3.1.4"
  }
