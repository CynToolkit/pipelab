{
  "name": "@pipelab/plugin-construct",
  "version": "1.0.1-beta.0",
  "license": "FSL-1.1-MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "default": "./dist/index.mjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "format": "oxfmt .",
    "lint": "oxlint .",
    "build": "tsdown"
  },
  "dependencies": {
    "@pipelab/plugin-core": "workspace:*",
    "es-toolkit": "1.25.2",
    "playwright": "1.48.2",
    "valibot": "0.42.1"
  },
  "devDependencies": {
    "@pipelab/tsconfig": "workspace:*",
    "@types/node": "24",
    "tsdown": "0.21.2",
    "typescript": "5.9.3"
  }
}
