{
  "name": "@pipelab/plugin-itch",
  "version": "1.0.1-beta.11",
  "license": "FSL-1.1-MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CynToolkit/pipelab.git",
    "directory": "plugins/plugin-itch"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "default": "./dist/index.mjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "scripts": {
    "format": "oxfmt .",
    "lint": "oxlint .",
    "build": "tsdown"
  },
  "dependencies": {
    "@pipelab/plugin-core": "workspace:*",
    "node-stream-zip": "1.15.0"
  },
  "devDependencies": {
    "@pipelab/tsconfig": "workspace:*",
    "@types/node": "24",
    "tsdown": "0.21.2",
    "typescript": "5.9.3"
  }
}
