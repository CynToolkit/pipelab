{
  "name": "@pipelab/shared",
  "version": "2.0.1-beta.20",
  "private": false,
  "description": "Shared logic and types for the Pipelab ecosystem",
  "license": "FSL-1.1-MIT",
  "author": "CynToolkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/CynToolkit/pipelab.git",
    "directory": "packages/shared"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "default": "./dist/index.mjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "scripts": {
    "build": "tsdown",
    "format": "oxfmt .",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@jitl/quickjs-singlefile-mjs-release-sync": "0.31.0",
    "@jitl/quickjs-wasmfile-release-sync": "0.31.0",
    "@pipelab/migration": "workspace:*",
    "@supabase/supabase-js": "2.99.3",
    "@types/node": "^24.12.2",
    "klona": "2.0.6",
    "nanoid": "5.0.7",
    "quickjs-emscripten": "0.31.0",
    "quickjs-emscripten-sync": "1.6.0",
    "tslog": "4.9.3",
    "type-fest": "4.26.1",
    "valibot": "0.42.1"
  },
  "devDependencies": {
    "@pipelab/tsconfig": "workspace:*",
    "esbuild-plugin-wasm": "1.1.0",
    "tsdown": "0.21.2",
    "typescript": "5.9.3"
  }
}
