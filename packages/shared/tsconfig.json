{
  "extends": "../tsconfig/commonjs.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@pipelab/plugin-core": ["./src/libs/plugin-core"],
      "@pipelab/plugin-core/*": ["./src/libs/plugin-core/*"],
      "@pipelab/core-app": ["./src/libs/core-app"],
      "@pipelab/shared/*": ["./src/*"]
    },
    "typeRoots": ["./src"],
    "types": ["global.d.ts", "wasm.d.ts"]
  },
  "include": ["src/**/*", "tests/**/*", "*.ts"],
  "exclude": ["node_modules", "dist"]
}
