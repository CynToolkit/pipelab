{
  "extends": "../tsconfig/commonjs.json",
  "compilerOptions": {
    "composite": false,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@pipelab/plugin-core": ["./src/libs/plugin-core"],
      "@pipelab/plugin-core/*": ["./src/libs/plugin-core/*"],
      "@pipelab/core-app": ["./src/libs/core-app"],
      "@pipelab/shared/*": ["./src/*"]
    },
    "typeRoots": ["./src"],
    "types": ["global.d.ts", "wasm.d.ts"]
  },
  "include": ["src/**/*", "tests/**/*", "*.ts", "src/**/*.json"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../migration" }
  ]
}
