{
  "name": "@pipelab/migration",
  "version": "1.0.1-beta.21",
  "private": false,
  "description": "Migration utilities for Pipelab data structures",
  "license": "FSL-1.1-MIT",
  "author": "CynToolkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/CynToolkit/pipelab.git",
    "directory": "packages/migration"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "default": "./dist/index.mjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "scripts": {
    "build": "tsdown",
    "format": "oxfmt .",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@types/node": "^24.12.2",
    "klona": "2.0.6",
    "semver": "^7.6.3",
    "valibot": "0.42.1"
  },
  "devDependencies": {
    "@pipelab/tsconfig": "workspace:*",
    "@types/semver": "^7.5.8",
    "tsdown": "0.21.2",
    "typescript": "5.9.3"
  }
}
