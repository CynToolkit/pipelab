{
  "name": "@pipelab/constants",
  "version": "1.0.1-beta.24",
  "private": false,
  "description": "Shared constants for the Pipelab ecosystem",
  "license": "FSL-1.1-MIT",
  "author": "CynToolkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/CynToolkit/pipelab.git",
    "directory": "packages/constants"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "default": "./dist/index.mjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "scripts": {
    "build": "tsdown",
    "format": "oxfmt .",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@types/node": "^24.12.2"
  },
  "devDependencies": {
    "@pipelab/tsconfig": "workspace:*",
    "tsdown": "0.21.2",
    "typescript": "^5.0.0"
  }
}
