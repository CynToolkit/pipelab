{
  "name": "@pipelab/app",
  "version": "1.37.4",
  "description": "-",
  "main": ".vite/build/main.js",
  "author": "Armaldio",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/CynToolkit/pipelab.git"
  },
  "homepage": "https://pipelab.app",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json --composite false",
    "start": "electron-forge start",
    "start:args": "electron-forge start -- --project ./tests/e2e/fixtures/folder-to-electron.json --action run",
    "dev": "pnpx cross-env UI_DEV_SERVER_URL=http://localhost:5173 NODE_OPTIONS=--enable-source-maps pnpm start",
    "test:unit": "vitest run -c vitest.config.mts",
    "test:unit:watch": "vitest watch -c vitest.config.mts",
    "test:e2e:raw": "vitest run -c tests/e2e/vitest.config.mts",
    "test:e2e:local": "pnpm package && pnpm test:e2e:raw",
    "test:e2e:pw": "echo 1",
    "build": "echo 'Desktop app is built via electron-forge (use pnpm package or pnpm make)'",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "make-dev-prerelease": "pnpm version prerelease --preid=dev",
    "supa:types": "supabase gen types typescript --project-id $VITE_SUPABASE_PROJECT_ID > src/shared/database.types.ts",
    "migrate-file": "pnpm tsx scripts/migrate-file.mts"
  },
  "dependencies": {
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "4.0.0",
    "@sentry/electron": "5.4.0",
    "electron-squirrel-startup": "1.0.1",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.4.0",
    "@electron-forge/maker-dmg": "7.4.0",
    "@electron-forge/maker-pkg": "7.8.1",
    "@electron-forge/maker-squirrel": "7.4.0",
    "@electron-forge/maker-zip": "7.4.0",
    "@electron-forge/plugin-fuses": "7.4.0",
    "@electron-forge/plugin-vite": "7.4.0",
    "@electron-forge/publisher-github": "7.4.0",
    "@electron/fuses": "1.8.0",
    "@electron/notarize": "2.5.0",
    "@eslint/eslintrc": "3.1.0",
    "@eslint/js": "9.13.0",
    "@pipelab/cli": "workspace:*",
    "@pipelab/constants": "workspace:*",
    "@pipelab/core-node": "workspace:*",
    "@pipelab/shared": "workspace:*",
    "@pipelab/tsconfig": "workspace:*",
    "@rushstack/eslint-patch": "1.10.4",
    "@sentry/vite-plugin": "2.22.6",
    "@types/electron-squirrel-startup": "1.0.2",
    "@types/fs-extra": "11.0.4",
    "@types/node": "22.7.9",
    "@types/ws": "8.18.1",
    "@typescript-eslint/parser": "8.11.0",
    "@vue/eslint-config-prettier": "9.0.0",
    "@vue/eslint-config-typescript": "13.0.0",
    "electron": "32.1.2",
    "eslint": "9.13.0",
    "fs-extra": "11.3.0",
    "globals": "15.11.0",
    "prettier": "3.3.3",
    "ts-node": "10.9.2",
    "tsx": "4.19.1",
    "typescript": "5.8.3",
    "vite": "6.3.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.1.4"
  }
}