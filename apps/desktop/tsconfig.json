{
  "extends": "../../packages/tsconfig/commonjs.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "baseUrl": ".",
    "outDir": "dist",
    "inlineSourceMap": true,
    "paths": {
      "@pipelab/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@pipelab/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@pipelab/constants": [
        "../../packages/constants/src/index.ts"
      ],
      "@pipelab/core-node": [
        "../../packages/core-node/src/index.ts"
      ],
      "@pipelab/migration": [
        "../../packages/migration/src/index.ts"
      ],
      "@pipelab/*": [
        "../../packages/shared/src/libs/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "*.ts",
    "*.mts",
    "package.json"
  ],
  "exclude": [
    "node_modules",
    "./assets/tauri/template/app/src-tauri",
    "dist",
    "out",
    "scripts",
    "./assets"
  ],
  "references": [
    { "path": "../../packages/constants" },
    { "path": "../../packages/shared" },
    { "path": "../../packages/core-node" },
    { "path": "../ui" }
  ]
}