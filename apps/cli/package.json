{
  "name": "@pipelab/cli",
  "version": "1.0.0",
  "private": true,
  "bin": "dist/index.cjs",
  "scripts": {
    "build": "NODE_ENV=production tsdown && pnpm copy:ui",
    "copy:ui": "node scripts/copy-ui.mjs",
    "pkg": "pnpm build && pkg . --output bin/pipelab",
    "dev": "NODE_ENV=development tsdown --watch --onSuccess \"NODE_ENV=development node dist/index.cjs serve\"",
    "watch": "tsdown --watch",
    "start": "node dist/index.cjs",
    "format": "oxfmt .",
    "lint": "oxlint ."
  },
  "dependencies": {
    "cac": "6.7.14",
    "serve-handler": "6.1.7"
  },
  "devDependencies": {
    "@pipelab/constants": "workspace:*",
    "@pipelab/core-node": "workspace:*",
    "@pipelab/shared": "workspace:*",
    "@pipelab/tsconfig": "workspace:*",
    "@types/node": "22.7.9",
    "@types/serve-handler": "6.1.4",
    "@yao-pkg/pkg": "6.14.1",
    "tsdown": "0.21.2",
    "typescript": "^5.0.0"
  },
  "pkg": {
    "scripts": [
      "dist/*.cjs"
    ],
    "assets": [
      "dist/*.wasm",
      "assets/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-win-x64",
      "node18-macos-x64"
    ],
    "outputPath": "bin"
  }
}
