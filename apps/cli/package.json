{
  "name": "@pipelab/cli",
  "version": "2.0.0",
  "private": true,
  "bin": "dist/index.cjs",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production tsdown",
    "package": "pnpm build && node scripts/build-package.mjs",
    "dev": "cross-env NODE_ENV=development tsdown --watch --onSuccess \"cross-env NODE_ENV=development node dist/index.js serve\"",
    "watch": "tsdown --watch",
    "start": "node dist/index.js",
    "test:e2e:raw": "vitest run -c tests/e2e/vitest.config.mts",
    "test:e2e": "pnpm run package && pnpm test:e2e:raw",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit -p tsconfig.json --composite false"
  },
  "dependencies": {
    "@sentry/node": "8.34.0",
    "cac": "6.7.14",
    "execa": "9.5.1",
    "serve-handler": "6.1.7"
  },
  "devDependencies": {
    "@pipelab/constants": "workspace:*",
    "@pipelab/core-node": "workspace:*",
    "@pipelab/shared": "workspace:*",
    "@pipelab/tsconfig": "workspace:*",
    "@types/node": "24.12.2",
    "@types/serve-handler": "6.1.4",
    "@yao-pkg/pkg": "6.15.0",
    "cross-env": "7.0.3",
    "nanoid": "5.0.8",
    "tsdown": "0.21.2",
    "typescript": "^5.0.0",
    "vitest": "3.1.4"
  },
  "pkg": {
    "scripts": [],
    "assets": [
      "dist/*.cjs",
      "dist/*.js",
      "dist/*.wasm",
      "package.json"
    ],
    "outputPath": "bin"
  }
}
