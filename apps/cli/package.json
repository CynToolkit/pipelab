{
  "name": "@pipelab/cli",
  "version": "2.0.0",
  "private": true,
  "bin": "dist/index.mjs",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production tsdown && pnpm copy:ui",
    "copy:ui": "node scripts/copy-ui.mjs",
    "pkg": "pnpm build && pkg . --output bin/pipelab",
    "dev": "cross-env NODE_ENV=development tsdown --watch --onSuccess \"cross-env NODE_ENV=development node dist/index.mjs serve\"",
    "watch": "tsdown --watch",
    "start": "node dist/index.mjs",
    "test:e2e:raw": "vitest run -c tests/e2e/vitest.config.mts",
    "test:e2e": "pnpm build && pnpm test:e2e:raw",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit -p tsconfig.json --composite false"
  },
  "dependencies": {
    "@sentry/node": "8.34.0",
    "cac": "6.7.14",
    "dotenv": "17.4.1",
    "serve-handler": "6.1.7"
  },
  "devDependencies": {
    "@pipelab/constants": "workspace:*",
    "@pipelab/core-node": "workspace:*",
    "@pipelab/shared": "workspace:*",
    "@pipelab/tsconfig": "workspace:*",
    "@types/node": "24.12.2",
    "@types/serve-handler": "6.1.4",
    "@yao-pkg/pkg": "6.14.1",
    "cross-env": "7.0.3",
    "execa": "9.5.1",
    "nanoid": "5.0.8",
    "tsdown": "0.21.2",
    "typescript": "^5.0.0",
    "vitest": "3.1.4"
  },
  "pkg": {
    "scripts": [
      "dist/*.mjs"
    ],
    "assets": [
      "dist/*.wasm",
      "assets/**/*"
    ],
    "targets": [
      "node24-linux-x64",
      "node24-win-x64",
      "node24-macos-x64"
    ],
    "outputPath": "bin"
  }
}
